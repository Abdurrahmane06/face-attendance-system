# FaceAttend — Environment Variables
# Copy this file to .env and adjust values

# Backend
DATABASE_URL=postgresql+asyncpg://faceattend:password@db:5432/faceattend
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
FACE_TOLERANCE=0.6
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ENVIRONMENT=development
LOG_LEVEL=INFO

# Frontend
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_TITLE=FaceAttend

# PostgreSQL
POSTGRES_USER=faceattend
POSTGRES_PASSWORD=password
POSTGRES_DB=faceattend

# PgAdmin
PGADMIN_EMAIL=admin@faceattend.local
PGADMIN_PASSWORD=admin
