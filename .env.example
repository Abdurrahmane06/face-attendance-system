# ============================================================
# FaceAttend — Variables d'environnement racine
# Copier ce fichier en .env et adapter les valeurs.
#   cp .env.example .env
# Ne jamais committer .env dans le dépôt.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=faceattend
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=faceattend

# ── JWT / Sécurité ───────────────────────────────────────────
# Générer une clé forte :
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Reconnaissance faciale ────────────────────────────────────
# Distance euclidienne : 0.0 = très strict / 1.0 = très permissif
FACE_TOLERANCE=0.6

# ── Uploads ──────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Application ──────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── PgAdmin (optionnel) ──────────────────────────────────────
PGADMIN_EMAIL=admin@faceattend.io
PGADMIN_PASSWORD=changeme_pgadmin
