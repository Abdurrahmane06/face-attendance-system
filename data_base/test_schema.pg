-- ======================================================================
-- test_schema.pg — Tests pgTAP pour le schéma de la base de données
--                  Système de pointage par reconnaissance faciale
-- ======================================================================
--
-- Utilisation :
--   1. Installer pgTAP sur le serveur PostgreSQL :
--        CREATE EXTENSION IF NOT EXISTS pgtap;
--   2. Exécuter le test :
--        psql -d faceattend -f data_base/init.sql
--        psql -d faceattend -f data_base/test_schema.pg
--   3. Ou avec pg_prove :
--        pg_prove -d faceattend data_base/test_schema.pg
-- ======================================================================

BEGIN;

-- Plan : nombre total de tests
SELECT plan(221);

-- ============================
-- Schéma par défaut : public
-- ============================

-- ============================
-- 1. EXTENSIONS
-- ============================
SELECT has_extension('pgcrypto', 'Extension pgcrypto doit être présente');

-- ============================
-- 2. TYPES ENUM
-- ============================
SELECT has_enum('public', 'profile_type', 'Type ENUM profile_type doit exister');
SELECT enum_has_labels('public', 'profile_type', ARRAY['student', 'employee', 'teacher', 'admin'], 'profile_type doit avoir 4 labels');

SELECT has_enum('public', 'auth_role', 'Type ENUM auth_role doit exister');
SELECT enum_has_labels('public', 'auth_role', ARRAY['admin', 'manager', 'user'], 'auth_role doit avoir 3 labels');

SELECT has_enum('public', 'attendance_method', 'Type ENUM attendance_method doit exister');
SELECT enum_has_labels('public', 'attendance_method', ARRAY['FACE', 'MANUAL', 'CARD', 'QR'], 'attendance_method doit avoir 4 labels');

-- ============================
-- 3. FONCTION TRIGGER
-- ============================
SELECT has_function('public', 'trigger_set_updated_at', '{}', 'Fonction trigger_set_updated_at doit exister');
SELECT function_lang_is('public', 'trigger_set_updated_at', 'plpgsql', 'trigger_set_updated_at doit être en plpgsql');
SELECT function_returns('public', 'trigger_set_updated_at', 'trigger', 'trigger_set_updated_at doit retourner trigger');

-- ============================
-- 4. TABLE users
-- ============================
SELECT has_table('public', 'users', 'Table users doit exister');
SELECT has_column('public', 'users', 'id', 'users.id doit exister');
SELECT col_type_is('public', 'users', 'id', 'uuid', 'users.id doit être UUID');
SELECT col_is_pk('public', 'users', 'id', 'users.id doit être PK');
SELECT col_has_default('public', 'users', 'id', 'users.id doit avoir DEFAULT gen_random_uuid()');
SELECT col_default_is('public', 'users', 'id', 'gen_random_uuid()', 'users.id DEFAULT doit être gen_random_uuid()');

SELECT has_column('public', 'users', 'email', 'users.email doit exister');
SELECT col_type_is('public', 'users', 'email', 'character varying(255)', 'users.email doit être VARCHAR(255)');
SELECT col_not_null('public', 'users', 'email', 'users.email doit être NOT NULL');
SELECT has_index('public', 'users', 'uq_users_email', 'users.email doit avoir un index unique');

SELECT has_column('public', 'users', 'password_hash', 'users.password_hash doit exister');
SELECT col_type_is('public', 'users', 'password_hash', 'character varying(255)', 'users.password_hash doit être VARCHAR(255)');
SELECT col_not_null('public', 'users', 'password_hash', 'users.password_hash doit être NOT NULL');

SELECT has_column('public', 'users', 'full_name', 'users.full_name doit exister');
SELECT col_type_is('public', 'users', 'full_name', 'character varying(255)', 'users.full_name doit être VARCHAR(255)');
SELECT col_not_null('public', 'users', 'full_name', 'users.full_name doit être NOT NULL');

SELECT has_column('public', 'users', 'profile_type', 'users.profile_type doit exister');
SELECT col_type_is('public', 'users', 'profile_type', 'profile_type', 'users.profile_type doit être ENUM profile_type');
SELECT col_not_null('public', 'users', 'profile_type', 'users.profile_type doit être NOT NULL');

SELECT has_column('public', 'users', 'auth_role', 'users.auth_role doit exister');
SELECT col_type_is('public', 'users', 'auth_role', 'auth_role', 'users.auth_role doit être ENUM auth_role');
SELECT col_not_null('public', 'users', 'auth_role', 'users.auth_role doit être NOT NULL');

SELECT has_column('public', 'users', 'identifier', 'users.identifier doit exister');
SELECT col_type_is('public', 'users', 'identifier', 'character varying(20)', 'users.identifier doit être VARCHAR(20)');
SELECT col_is_unique('public', 'users', 'identifier', 'users.identifier doit être UNIQUE');

SELECT has_column('public', 'users', 'phone', 'users.phone doit exister');
SELECT col_type_is('public', 'users', 'phone', 'character varying(20)', 'users.phone doit être VARCHAR(20)');

SELECT has_column('public', 'users', 'is_active', 'users.is_active doit exister');
SELECT col_type_is('public', 'users', 'is_active', 'boolean', 'users.is_active doit être BOOLEAN');
SELECT col_default_is('public', 'users', 'is_active', 'true', 'users.is_active DEFAULT doit être true');

SELECT has_column('public', 'users', 'created_at', 'users.created_at doit exister');
SELECT col_type_is('public', 'users', 'created_at', 'timestamp with time zone', 'users.created_at doit être TIMESTAMPTZ');
SELECT col_has_default('public', 'users', 'created_at', 'users.created_at doit avoir DEFAULT');

SELECT has_column('public', 'users', 'updated_at', 'users.updated_at doit exister');
SELECT col_type_is('public', 'users', 'updated_at', 'timestamp with time zone', 'users.updated_at doit être TIMESTAMPTZ');
SELECT col_has_default('public', 'users', 'updated_at', 'users.updated_at doit avoir DEFAULT');

-- Trigger updated_at sur users
SELECT has_trigger('public', 'users', 'trg_users_updated_at', 'users doit avoir le trigger trg_users_updated_at');

-- (Testé ci-dessus avec les colonnes)

-- ============================
-- 5. TABLE groups
-- ============================
SELECT has_table('public', 'groups', 'Table groups doit exister');
SELECT has_column('public', 'groups', 'id', 'groups.id doit exister');
SELECT col_type_is('public', 'groups', 'id', 'uuid', 'groups.id doit être UUID');
SELECT col_is_pk('public', 'groups', 'id', 'groups.id doit être PK');

SELECT has_column('public', 'groups', 'name', 'groups.name doit exister');
SELECT col_type_is('public', 'groups', 'name', 'character varying(255)', 'groups.name doit être VARCHAR(255)');
SELECT col_not_null('public', 'groups', 'name', 'groups.name doit être NOT NULL');
SELECT col_is_unique('public', 'groups', 'name', 'groups.name doit être UNIQUE');

SELECT has_column('public', 'groups', 'description', 'groups.description doit exister');
SELECT col_type_is('public', 'groups', 'description', 'text', 'groups.description doit être TEXT');

SELECT has_column('public', 'groups', 'created_at', 'groups.created_at doit exister');
SELECT col_type_is('public', 'groups', 'created_at', 'timestamp with time zone', 'groups.created_at doit être TIMESTAMPTZ');

-- ============================
-- 6. TABLE user_groups (jonction)
-- ============================
SELECT has_table('public', 'user_groups', 'Table user_groups doit exister');
SELECT has_column('public', 'user_groups', 'user_id', 'user_groups.user_id doit exister');
SELECT col_type_is('public', 'user_groups', 'user_id', 'uuid', 'user_groups.user_id doit être UUID');
SELECT col_not_null('public', 'user_groups', 'user_id', 'user_groups.user_id doit être NOT NULL');

SELECT has_column('public', 'user_groups', 'group_id', 'user_groups.group_id doit exister');
SELECT col_type_is('public', 'user_groups', 'group_id', 'uuid', 'user_groups.group_id doit être UUID');
SELECT col_not_null('public', 'user_groups', 'group_id', 'user_groups.group_id doit être NOT NULL');

-- PK composite
SELECT col_is_pk('public', 'user_groups', ARRAY['user_id', 'group_id'], 'user_groups PK doit être composite (user_id, group_id)');

-- FK
SELECT col_is_fk('public', 'user_groups', 'user_id', 'user_groups.user_id doit être FK → users.id');
SELECT col_is_fk('public', 'user_groups', 'group_id', 'user_groups.group_id doit être FK → groups.id');

