SELECT has_column('public', 'sessions', 'created_at', 'sessions.created_at doit exister');

-- CHECK end_time > start_time
SELECT col_has_check('public', 'sessions', ARRAY['end_time', 'start_time']::name[], 'CHECK end_time > start_time doit exister sur sessions');

