SELECT has_column('public', 'face_encodings', 'encoding', 'face_encodings.encoding doit exister');

-- encoding peut être VECTOR(128) si pgvector, sinon TEXT
SELECT ok(
    (SELECT EXISTS (
        SELECT 1 FROM information_schema.columns
        WHERE table_schema = 'public' AND table_name = 'face_encodings' AND column_name = 'encoding'
        AND (udt_name = 'vector' OR data_type = 'text')
    )),
    'face_encodings.encoding doit être VECTOR(128) (pgvector) ou TEXT (fallback)'
);

SELECT has_column('public', 'face_encodings', 'encoding_json', 'face_encodings.encoding_json doit exister');
SELECT col_type_is('public', 'face_encodings', 'encoding_json', 'text', 'face_encodings.encoding_json doit être TEXT');

SELECT has_column('public', 'face_encodings', 'confidence', 'face_encodings.confidence doit exister');
SELECT col_type_is('public', 'face_encodings', 'confidence', 'double precision', 'face_encodings.confidence doit être FLOAT/double precision');

SELECT has_column('public', 'face_encodings', 'created_at', 'face_encodings.created_at doit exister');

-- CHECK au moins encoding ou encoding_json non nul
SELECT col_has_check('public', 'face_encodings', ARRAY['encoding', 'encoding_json']::name[], 'CHECK encoding OR encoding_json pas nul doit exister sur face_encodings');

