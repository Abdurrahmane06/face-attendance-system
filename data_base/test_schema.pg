-- ============================
-- 15. TESTS D'INTÉGRITÉ (données seed)
-- ============================
-- Vérifier que les données seed sont présentes
SELECT ok(
    (SELECT COUNT(*) FROM users) >= 6,
    'Au moins 6 utilisateurs seed doivent être présents'
);

SELECT ok(
    (SELECT COUNT(*) FROM groups) >= 3,
    'Au moins 3 groupes seed doivent être présents'
);

SELECT ok(
    (SELECT COUNT(*) FROM sessions) >= 2,
    'Au moins 2 sessions seed doivent être présentes'
);

SELECT ok(
    (SELECT COUNT(*) FROM attendance_records) >= 3,
    'Au moins 3 pointages seed doivent être présents'
);

SELECT ok(
    (SELECT COUNT(*) FROM user_groups) >= 4,
    'Au moins 4 associations user_groups seed doivent être présentes'
);

-- Vérifier que les emails uniques sont respectés
SELECT ok(
    (SELECT COUNT(*) FROM users) = (SELECT COUNT(DISTINCT email) FROM users),
    'Tous les emails des utilisateurs doivent être uniques'
);

-- Vérifier que chaque pointage respecte check_out > check_in
SELECT ok(
    NOT EXISTS (
        SELECT 1 FROM attendance_records
        WHERE check_out IS NOT NULL AND check_out <= check_in
    ),
    'Tous les check_out doivent être > check_in quand renseignés'
);

-- Vérifier que les sessions respectent end_time > start_time
SELECT ok(
    NOT EXISTS (
        SELECT 1 FROM sessions WHERE end_time <= start_time
    ),
    'Tous les end_time doivent être > start_time'
);

-- ============================
-- 16. TESTS COMPORTEMENTAUX (contraintes)
-- ============================
PREPARE insert_duplicate_free_attendance AS
    INSERT INTO attendance_records (user_id, session_id, record_date, check_in, method)
    VALUES (
        (SELECT id FROM users ORDER BY created_at LIMIT 1),
        NULL,
        CURRENT_DATE,
        now(),
        'FACE'
    );

-- Premier insert doit réussir
SELECT lives_ok(
    'insert_duplicate_free_attendance',
    'Premier pointage libre du jour doit réussir'
);

-- Second insert (même user, même jour, session_id NULL) doit échouer
SELECT throws_ok(
    'insert_duplicate_free_attendance',
    23505,  -- unique_violation
    NULL,
    'Second pointage libre du jour doit lever une violation de contrainte UNIQUE'
);

-- Tester CHECK end_time > start_time
PREPARE insert_invalid_session AS
    INSERT INTO sessions (title, start_time, end_time)
    VALUES ('Test invalide', now(), now() - INTERVAL '1 hour');

SELECT throws_ok(
    'insert_invalid_session',
    23514,  -- check_violation
    NULL,
    'Session avec end_time < start_time doit lever CHECK violation'
);

-- Tester CHECK check_out > check_in
PREPARE insert_invalid_checkout AS
    INSERT INTO attendance_records (user_id, session_id, record_date, check_in, check_out, method)
    VALUES (
        (SELECT id FROM users ORDER BY created_at LIMIT 1),
        NULL,
        CURRENT_DATE + 1,
        now(),
        now() - INTERVAL '1 hour',
        'FACE'
    );

SELECT throws_ok(
    'insert_invalid_checkout',
    23514,  -- check_violation
    NULL,
    'Pointage avec check_out < check_in doit lever CHECK violation'
);

-- Tester trigger updated_at
PREPARE update_user AS
    UPDATE users SET phone = '+221 77 999 99 99'
    WHERE email = 'admin@example.com';

SELECT lives_ok('update_user', 'UPDATE sur users doit réussir');

SELECT ok(
    (SELECT updated_at > created_at FROM users WHERE email = 'admin@example.com'),
    'updated_at doit être > created_at après UPDATE (trigger)'
);

-- ============================
-- FIN
-- ============================
SELECT * FROM finish();

ROLLBACK;
