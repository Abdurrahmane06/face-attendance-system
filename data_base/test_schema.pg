SELECT col_not_null('public', 'sessions', 'title', 'sessions.title doit être NOT NULL');

SELECT has_column('public', 'sessions', 'start_time', 'sessions.start_time doit exister');
SELECT col_type_is('public', 'sessions', 'start_time', 'timestamp with time zone', 'sessions.start_time doit être TIMESTAMPTZ');
