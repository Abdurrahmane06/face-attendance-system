# FaceAttend — Frontend Environment Variables
# Copy this file to frontend/.env for local development WITHOUT Docker.
# In Docker, VITE_ variables must be baked at build time or set before `npm run dev`.

# URL of the backend API (no trailing slash)
VITE_API_URL=http://localhost:8000/api/v1

# Application title (displayed in browser tab / header)
VITE_APP_TITLE=FaceAttend
